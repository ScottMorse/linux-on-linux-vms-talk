# How the host-side tools combine to run and feed a guest VM.
# KVM and QEMU present virtual hardware to the guest; virtiofsd bridges a host
# directory into the guest as a shared mount, so it connects to both sides.
vars: {
  ...@_theme
}

direction: up

host: Host (your main system) {
  style.stroke: "#484f58"
  style.fill: "#100d0d"
  style.font-color: "#c9d1d9"

  virtmanager: virt-manager (GUI) {
    style.stroke: "#1dff99"
    style.font-color: "#c9d1d9"
  }
  libvirt: libvirt\nAPI, CLI, daemons {
    style.stroke: "#1dff99"
    style.font-color: "#c9d1d9"
  }
  qemu: QEMU\nHardware emulation {
    style.stroke: "#1dff99"
    style.font-color: "#c9d1d9"
  }
  kernel: Linux kernel {
    style.stroke: "#8b949e"
    style.fill: "#100d0d"
    style.font-color: "#c9d1d9"

    kvm: KVM\nCPU + RAM allocation {
      style.stroke: "#1dff99"
      style.font-color: "#c9d1d9"
    }
  }
  share: Shared directory\ne.g. ~/my-shared-files {
    style.stroke: "#8b949e"
    style.font-color: "#c9d1d9"
  }
  disk: Disk Image\nVM OS installation\n(qcow2 / real disk (bare metal)) {
    shape: cylinder
    style.stroke: "#1dff99"
    style.font-color: "#c9d1d9"
  }
  virtiofsd: virtiofsd {
    style.stroke: "#58a6ff"
    style.font-color: "#c9d1d9"
  }
}

guest: Guest VM {
  style.stroke: "#484f58"
  style.fill: "#100d0d"
  style.font-color: "#c9d1d9"

  vcpu: Virtual CPU + RAM {
    style.stroke: "#1dff99"
    style.font-color: "#c9d1d9"
  }
  devices: Virtual devices {
    style.stroke: "#1dff99"
    style.font-color: "#c9d1d9"
  }
  drive: Virtual disk\nVM's OS root/boot {
    shape: cylinder
    style.stroke: "#1dff99"
    style.font-color: "#c9d1d9"
  }
  mount: External volume\n(Mountable)\ne.g. /mnt/share {
    style.stroke: "#4d555e"
    style.font-color: "#c9d1d9"
  }
} 

# Management chain on the host.
host.virtmanager -> host.libvirt: controls
host.libvirt -> host.qemu: manages
host.libvirt -> host.virtiofsd: manages
host.qemu -> host.kernel.kvm: uses

# Virtual hardware presented to the guest.
host.kernel.kvm -> guest.vcpu: provides
host.qemu -> guest.devices: emulates

# virtiofsd bridges a host directory to a guest mount.
host.share -> host.virtiofsd: exposed
host.virtiofsd -> guest.mount: provides

# A disk image (or host partition) backs the guest's virtual disk.
host.disk -> guest.drive: attached
